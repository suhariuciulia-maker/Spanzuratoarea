<Window x:Class="Spanzuratoarea_SuhariucIulia.Views.GameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Spanzuratoarea_SuhariucIulia.Helpers"
        Title="Game" Height="600" Width="450"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <local:MistakeToVisibilityConverter x:Key="MistakeToVisibility"/>
    </Window.Resources>

    <DockPanel>

        <!-- MENIU -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="New Game" Command="{Binding NewGameCommand}" />
                <MenuItem Header="Open Game" Command="{Binding OpenGameCommand}" />
                <MenuItem Header="Save Game" Command="{Binding SaveGameCommand}" />
                <MenuItem Header="Statistics" Command="{Binding StatisticsCommand}" />
                <Separator/>
                <MenuItem Header="Cancel" Command="{Binding CancelCommand}" />
            </MenuItem>

            <MenuItem Header="Help">
                <MenuItem Header="About" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- CONTINUT -->
        <StackPanel Margin="10">

            <!-- USER -->
            <TextBlock Text="{Binding UserName}"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="5"/>

            <Image Source="{Binding UserImage}"
                   Width="100"
                   Height="100"
                   HorizontalAlignment="Center"
                   Margin="5"/>

            <!-- HANGMAN IMAGE -->
            <Image Source="{Binding HangmanImage}"
                   Width="150"
                   Height="150"
                   HorizontalAlignment="Center"
                   Margin="5"/>

            <!-- X-uri greseli -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="X" FontSize="20"
                           Visibility="{Binding Mistakes, Converter={StaticResource MistakeToVisibility}, ConverterParameter=1}"/>
                <TextBlock Text="X" FontSize="20"
                           Visibility="{Binding Mistakes, Converter={StaticResource MistakeToVisibility}, ConverterParameter=2}"/>
                <TextBlock Text="X" FontSize="20"
                           Visibility="{Binding Mistakes, Converter={StaticResource MistakeToVisibility}, ConverterParameter=3}"/>
                <TextBlock Text="X" FontSize="20"
                           Visibility="{Binding Mistakes, Converter={StaticResource MistakeToVisibility}, ConverterParameter=4}"/>
                <TextBlock Text="X" FontSize="20"
                           Visibility="{Binding Mistakes, Converter={StaticResource MistakeToVisibility}, ConverterParameter=5}"/>
                <TextBlock Text="X" FontSize="20"
                           Visibility="{Binding Mistakes, Converter={StaticResource MistakeToVisibility}, ConverterParameter=6}"/>
            </StackPanel>

            <!-- CATEGORII -->
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Width="150"
                      HorizontalAlignment="Center"
                      Margin="5"/>

            <!-- CUVANT -->
            <TextBlock Text="{Binding DisplayWord}"
                       FontSize="30"
                       HorizontalAlignment="Center"
                       Margin="5"/>

            <!-- TIMER -->
            <TextBlock Text="{Binding SecondsLeft}"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="5"/>

            <!-- NIVEL -->
            <TextBlock Text="{Binding Level}"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="5"/>

            <!-- LITERE -->
            <ItemsControl ItemsSource="{Binding Alphabet}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}"
                                Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Margin="2"
                                Width="30"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

    </DockPanel>
</Window>